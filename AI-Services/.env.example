# Environment Configuration for RealTimeSearch Agent
# Copy this file to .env and fill in your actual values

# =============================================================================
# SerpAPI Configuration
# =============================================================================
# Get your free API key at: https://serpapi.com/manage-api-key
# Free plan includes 100 searches per month
SERPAPI_API_KEY=your_serpapi_key_here

# =============================================================================
# Cache Configuration
# =============================================================================
# Cache TTL in seconds (default: 3600 = 1 hour)
SEARCH_CACHE_TTL=3600

# Maximum cache size (number of cached searches)
SEARCH_CACHE_MAXSIZE=1000

# =============================================================================
# Search Configuration
# =============================================================================
# Default number of results per search
DEFAULT_SEARCH_RESULTS=10

# Default location for searches
DEFAULT_SEARCH_LOCATION=Global

# Default language for searches
DEFAULT_SEARCH_LANGUAGE=en

# =============================================================================
# Educational Content Configuration
# =============================================================================
# Enable educational content filtering (true/false)
ENABLE_EDUCATIONAL_FILTERING=true

# Educational domains to prioritize (comma-separated)
EDUCATIONAL_DOMAINS=edu,scholar.google.com,wikipedia.org,khanacademy.org,coursera.org,edx.org,mit.edu,stanford.edu,harvard.edu,youtube.com/watch,arxiv.org,researchgate.net

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable detailed request logging (true/false)
ENABLE_REQUEST_LOGGING=false

# =============================================================================
# Performance Configuration
# =============================================================================
# Request timeout in seconds
REQUEST_TIMEOUT=30

# Maximum retries for failed requests
MAX_RETRIES=3

# Delay between retries (seconds)
RETRY_DELAY=1

# =============================================================================
# API Rate Limiting
# =============================================================================
# Requests per minute limit
REQUESTS_PER_MINUTE=60

# Enable rate limiting (true/false)
ENABLE_RATE_LIMITING=true

# =============================================================================
# Security Configuration
# =============================================================================
# Enable secure HTTPS only (true/false)
HTTPS_ONLY=true

# Enable API key validation (true/false)
VALIDATE_API_KEY=true
